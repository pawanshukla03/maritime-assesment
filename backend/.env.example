# Copy this file to .env and fill in your values.
# On Windows you can: copy .env.example .env

# Required for chat/embeddings
OPENAI_API_KEY=sk-proj-your-key-here

# GitHub repo with PDFs (optional; use token for private repos)
# Example with token: https://YOUR_GITHUB_TOKEN@github.com/Beto22/acai/tree/main/WAC
# Example without token (public repo): https://github.com/Beto22/acai/tree/main/WAC
GITHUB_PDF_REPO_URL=https://github.com/Beto22/acai/tree/main/WAC

# Optional: local PDF instead of GitHub (if GITHUB_PDF_REPO_URL is not set)
# PDF_PATH=C:\path\to\file.pdf
